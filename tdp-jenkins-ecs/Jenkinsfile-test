pipeline {
    agent {
        label 'docker-agent'
    }

    stages {
        stage('Check Agent') {
            steps {
                sh 'echo "Running on: $(hostname)"'
                sh 'whoami'
                sh 'java -version'
            }
        }

        stage('Sleep to observe container') {
            steps {
                sh 'sleep 20'
            }
        }
    }
}