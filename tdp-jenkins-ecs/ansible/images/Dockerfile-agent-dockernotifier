FROM jenkins/inbound-agent:latest-jdk21

LABEL container.registry="swrgenesis" \
      image.name="agent-dockerNotifier" \
      version="1.0" \
      author="alejandro.more" \
      commit-id="manual-build" \
      build.date="2026-03-15"

USER root

ENV LANG=en_US.UTF-8 \
    LANGUAGE=en_US:en \
    LC_ALL=en_US.UTF-8

# Base tools
RUN apt-get update && apt-get install -y \
    git \
    curl \
    jq \
    openssh-client \
    locales \
    ca-certificates \
    docker.io \
    bash \
    tar \
    gzip \
    python3 \
    python3-pip \
 && rm -rf /var/lib/apt/lists/*

# Locale
RUN echo "en_US.UTF-8 UTF-8" >> /etc/locale.gen \
 && locale-gen \
 && update-locale LANG=en_US.UTF-8

# Bash como shell por defecto
RUN ln -sf /bin/bash /bin/sh

# Permitir docker dentro del agente
RUN groupadd -f docker \
 && usermod -aG docker jenkins

USER jenkins