FROM jenkins/inbound-agent:latest-jdk21

LABEL container.registry="acrgenesis" \
      image.name="agent-genesisHuawei" \
      version="1.1" \
      author="hfarroc" \
      build.date="2026-03-15"

USER root

ENV LANG=en_US.UTF-8
ENV LANGUAGE=en_US:en
ENV LC_ALL=en_US.UTF-8

# ==========================================
# Base packages
# ==========================================
RUN apt-get update && apt-get install -y \
    git \
    openssh-client \
    curl \
    jq \
    locales \
    ca-certificates \
    docker.io \
    tar \
    gzip \
    bash \
    unzip \
 && rm -rf /var/lib/apt/lists/*

RUN echo "en_US.UTF-8 UTF-8" >> /etc/locale.gen \
 && locale-gen \
 && update-locale LANG=en_US.UTF-8

# ==========================================
# Maven
# Fuente oficial Apache archive
# https://archive.apache.org/dist/maven/
# ==========================================
RUN curl -fsSL https://archive.apache.org/dist/maven/maven-3/3.9.9/binaries/apache-maven-3.9.9-bin.tar.gz \
    -o /tmp/maven.tar.gz \
 && tar -xzf /tmp/maven.tar.gz -C /opt \
 && ln -s /opt/apache-maven-3.9.9/bin/mvn /usr/local/bin/mvn \
 && rm -rf /tmp/maven.tar.gz

# ==========================================
# kubectl
# Fuente oficial Kubernetes
# https://dl.k8s.io/
# ==========================================
RUN curl -LO https://dl.k8s.io/release/v1.30.1/bin/linux/amd64/kubectl \
 && install -o root -g root -m 0755 kubectl /usr/local/bin/kubectl \
 && rm kubectl

# ==========================================
# Helm
# Script oficial Helm
# https://github.com/helm/helm
# ==========================================
RUN curl -fsSL https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash

# ==========================================
# Huawei Cloud CLI (hcloud)
# Script oficial que ya validaste
# ==========================================
RUN echo "Installing Huawei Cloud CLI..." \
 && curl -sSL https://ap-southeast-3-hwcloudcli.obs.ap-southeast-3.myhuaweicloud.com/cli/latest/hcloud_install.sh \
      -o /tmp/hcloud_install.sh \
 && chmod +x /tmp/hcloud_install.sh \
 && echo "y" | /tmp/hcloud_install.sh -y \
 && rm -f /tmp/hcloud_install.sh

# ==========================================
# yq (YAML processor)
# https://github.com/mikefarah/yq
# ==========================================
RUN curl -L https://github.com/mikefarah/yq/releases/latest/download/yq_linux_amd64 \
    -o /usr/local/bin/yq \
 && chmod +x /usr/local/bin/yq

# ==========================================
# Bash default
# ==========================================
RUN ln -sf /bin/bash /bin/sh

# ==========================================
# Permitir usar docker
# ==========================================
RUN groupadd -f docker && usermod -aG docker jenkins

USER jenkins