FROM jenkins/inbound-agent:latest-jdk21

LABEL container.registry="acrgenesis" \
      image.name="agent-genesisImageScan" \
      version="1.0" \
      author="platform-team" \
      description="Jenkins ephemeral agent for Genesis ImageScan stage"

USER root

# ------------------------------------------------
# Environment
# ------------------------------------------------
ENV LANG=en_US.UTF-8
ENV LANGUAGE=en_US:en
ENV LC_ALL=en_US.UTF-8

# ------------------------------------------------
# Install base packages
# ------------------------------------------------
RUN apt-get update && apt-get install -y \
    git \
    openssh-client \
    curl \
    jq \
    locales \
    ca-certificates \
    wget \
    gnupg \
 && rm -rf /var/lib/apt/lists/*

# ------------------------------------------------
# Configure UTF-8 locale
# ------------------------------------------------
RUN echo "en_US.UTF-8 UTF-8" >> /etc/locale.gen \
 && locale-gen \
 && update-locale LANG=en_US.UTF-8

# ------------------------------------------------
# Install Maven
# ------------------------------------------------
RUN curl -fsSL https://archive.apache.org/dist/maven/maven-3/3.9.9/binaries/apache-maven-3.9.9-bin.tar.gz -o /tmp/maven.tar.gz \
 && tar -xzf /tmp/maven.tar.gz -C /opt \
 && ln -s /opt/apache-maven-3.9.9/bin/mvn /usr/local/bin/mvn \
 && rm -rf /tmp/maven.tar.gz

# ------------------------------------------------
# Install Trivy
# ------------------------------------------------
RUN wget -qO - https://aquasecurity.github.io/trivy-repo/deb/public.key \
 | gpg --dearmor -o /usr/share/keyrings/trivy.gpg \
 && echo "deb [signed-by=/usr/share/keyrings/trivy.gpg] https://aquasecurity.github.io/trivy-repo/deb generic main" \
 > /etc/apt/sources.list.d/trivy.list \
 && apt-get update \
 && apt-get install -y trivy \
 && rm -rf /var/lib/apt/lists/*

# ------------------------------------------------
# Install Huawei OBS util
# ------------------------------------------------
RUN curl -L https://obs-community.obs.cn-north-1.myhuaweicloud.com/obsutil/current/obsutil_linux_amd64.tar.gz \
 | tar zx \
 && mv obsutil*/obsutil /usr/local/bin/obsutil \
 && chmod +x /usr/local/bin/obsutil

# ------------------------------------------------
# Create Trivy cache directory
# ------------------------------------------------
RUN mkdir -p /home/jenkins/trivy \
 && chown -R jenkins:jenkins /home/jenkins/trivy

# ------------------------------------------------
# Make bash default shell
# ------------------------------------------------
RUN ln -sf /bin/bash /bin/sh

USER jenkins