FROM jenkins/inbound-agent:jdk21

LABEL container.registry="acrgenesis" \
      image.name="agent-genesisFrontNodeLTS" \
      version="1.0" \
      author="devsecops" \
      build.date="2026-03-12"

USER root

# ------------------------------------------------
# Variables de entorno
# ------------------------------------------------
ENV LANG=en_US.UTF-8 \
    LANGUAGE=en_US:en \
    LC_ALL=en_US.UTF-8 \
    JAVA_TOOL_OPTIONS="-Dfile.encoding=UTF-8" \
    DOTNET_SYSTEM_GLOBALIZATION_INVARIANT=1 \
    DEBIAN_FRONTEND=noninteractive

# ------------------------------------------------
# Instalar dependencias base
# ------------------------------------------------
RUN apt-get update && apt-get install -y \
    git \
    curl \
    wget \
    jq \
    unzip \
    gnupg \
    ca-certificates \
    python3 \
    python3-pip \
    python3-venv \
    locales \
    apt-transport-https \
    libicu-dev \
    grep \
    findutils \
    coreutils \
    build-essential \
    tar \
 && rm -rf /var/lib/apt/lists/*

# ------------------------------------------------
# Configurar locale UTF-8
# ------------------------------------------------
RUN echo "en_US.UTF-8 UTF-8" >> /etc/locale.gen \
 && locale-gen \
 && update-locale LANG=en_US.UTF-8

# ------------------------------------------------
# Crear virtualenv Python (evita PEP 668)
# ------------------------------------------------
RUN python3 -m venv /opt/security-tools

# ------------------------------------------------
# Actualizar pip
# ------------------------------------------------
RUN /opt/security-tools/bin/pip install --upgrade pip

# ------------------------------------------------
# Instalar herramientas DevSecOps
# ------------------------------------------------
RUN /opt/security-tools/bin/pip install --no-cache-dir \
    detect-secrets \
    whispers

# Agregar herramientas al PATH
ENV PATH="/opt/security-tools/bin:$PATH"

# ------------------------------------------------
# Instalar Gitleaks
# ------------------------------------------------
RUN wget https://github.com/gitleaks/gitleaks/releases/download/v8.18.2/gitleaks_8.18.2_linux_x64.tar.gz \
 && tar -xzf gitleaks_8.18.2_linux_x64.tar.gz \
 && mv gitleaks /usr/local/bin/gitleaks \
 && chmod +x /usr/local/bin/gitleaks \
 && rm gitleaks_8.18.2_linux_x64.tar.gz

# ------------------------------------------------
# Instalar PowerShell
# ------------------------------------------------
RUN wget https://github.com/PowerShell/PowerShell/releases/download/v7.4.2/powershell-7.4.2-linux-x64.tar.gz \
 && mkdir -p /opt/microsoft/powershell/7 \
 && tar zxf powershell-7.4.2-linux-x64.tar.gz -C /opt/microsoft/powershell/7 \
 && ln -s /opt/microsoft/powershell/7/pwsh /usr/bin/pwsh \
 && rm powershell-7.4.2-linux-x64.tar.gz

# ------------------------------------------------
# Instalar Azure PowerShell modules
# ------------------------------------------------
RUN pwsh -Command "Install-Module Az -Scope AllUsers -Force -AllowClobber"

# ------------------------------------------------
# Instalar yq (útil para pipelines YAML)
# ------------------------------------------------
RUN wget https://github.com/mikefarah/yq/releases/latest/download/yq_linux_amd64 \
 && mv yq_linux_amd64 /usr/local/bin/yq \
 && chmod +x /usr/local/bin/yq

# ------------------------------------------------
# Instalar OBSUTIL (Huawei Cloud OBS CLI)
# ------------------------------------------------
RUN echo "Installing obsutil..." \
 && curl -Lk https://obs-community.obs.myhuaweicloud.com/obsutil/current/obsutil_linux_amd64.tar.gz -o /tmp/obsutil.tar.gz \
 && tar -xzf /tmp/obsutil.tar.gz -C /tmp \
 && cp /tmp/obsutil_linux_amd64_*/obsutil /usr/local/bin/obsutil \
 && chmod +x /usr/local/bin/obsutil \
 && rm -rf /tmp/obsutil*

RUN /usr/local/bin/obsutil version

# ------------------------------------------------
# Instalar Maven
# ------------------------------------------------
RUN curl -fsSL https://archive.apache.org/dist/maven/maven-3/3.9.9/binaries/apache-maven-3.9.9-bin.tar.gz -o /tmp/maven.tar.gz \
 && tar -xzf /tmp/maven.tar.gz -C /opt \
 && ln -s /opt/apache-maven-3.9.9/bin/mvn /usr/local/bin/mvn \
 && rm -rf /tmp/maven.tar.gz

# ------------------------------------------------
# Crear directorios usados por Jenkins
# ------------------------------------------------
RUN mkdir -p /home/jenkins/workspace \
 && chown -R jenkins:jenkins /home/jenkins

# ------------------------------------------------
# Limpiar caches
# ------------------------------------------------
RUN apt-get clean

USER jenkins