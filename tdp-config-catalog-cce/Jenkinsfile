@Library('shared-lib') _

pipeline {
    agent {
        label 'agent-huawei'
    }

    options {
        disableConcurrentBuilds()
    }

    parameters {
        choice(
            name: 'ACTION',
            choices: ['deploy', 'destroy'],
            description: 'Acción sobre el ambiente'
        )
        choice(
            name: 'CCE_BASE_TYPE',
            choices: ['', 'standard', 'turbo'],
            description: 'Selecciona el tipo de infraestructura base CCE'
        )
        choice(
            name: 'RUN_HELM_ADDONS',
            choices: ['', 'ingress', 'gateway'],
            description: 'Selecciona el tipo de infraestructura base CCE'
        )
        booleanParam(
            name: 'RUN_TERRAFORM_WORKLOAD_IDENTITY',
            defaultValue: false,
            description: 'Construir infraestructura con Terraform Workload Identity'
        )
        booleanParam(
            name: 'RUN_HELM_WORKLOAD_IDENTITY',
            defaultValue: false,
            description: 'Desplegar Jenkins con Helm'
        )
        booleanParam(
            name: 'RUN_HELM_ARGO_ROLLOUTS',
            defaultValue: false,
            description: 'Desplegar Argo Rollouts'
        )
    }

    environment {
        TF_DIR_TURBO    = 'tdp-config-catalog-cce/terraform/base-turbo'
        TF_DIR_STANDARD = 'tdp-config-catalog-cce/terraform/base-standard'
        TF_DIR_WK       = 'tdp-config-catalog-cce/terraform/workload-identity'
        HELM_DIR_AO_NI  = 'tdp-config-catalog-cce/helm/addons/nginx-ingress'
        HELM_DIR_AO_GA  = 'tdp-config-catalog-cce/helm/addons/gateway-api'
        HELM_DIR_WK     = 'tdp-config-catalog-cce/helm/demo-app/workload-identity'
        REGION          = 'la-south-2'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        // -----------------------------
        // Terraform: infraestructura base CCE Turbo
        // -----------------------------
        stage('Terraform Deploy Base Turbo') {
            when {
                expression { params.CCE_BASE_TYPE == 'turbo' }
            }
            steps {
                withCredentials([
                    string(credentialsId: 'hwc-access-key', variable: 'HW_ACCESS_KEY'),
                    string(credentialsId: 'hwc-secret-key', variable: 'HW_SECRET_KEY'),
                    string(credentialsId: 'hwc-access-key', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'hwc-secret-key', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    script {

                        terraformDeploy(
                            dir: env.TF_DIR_TURBO,
                            varsFile: 'local.tfvars',
                            action: params.ACTION,
                            outputs: [
                                'elb_public_ip', 
                                'elb_public_id',
                                'kubeconfig'
                            ]
                        )

                    }
                }
            }
        }

        // -----------------------------
        // Terraform: infraestructura base CCE Standard
        // -----------------------------
        stage('Terraform Deploy Base Standard') {
            when {
               expression { params.CCE_BASE_TYPE == 'standard' }
            }
            steps {
                withCredentials([
                    string(credentialsId: 'hwc-access-key', variable: 'HW_ACCESS_KEY'),
                    string(credentialsId: 'hwc-secret-key', variable: 'HW_SECRET_KEY'),
                    string(credentialsId: 'hwc-access-key', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'hwc-secret-key', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    script {

                        terraformDeploy(
                            dir: env.TF_DIR_STANDARD,
                            varsFile: 'local.tfvars',
                            action: params.ACTION,
                            outputs: [
                                'elb_public_ip', 
                                'elb_public_id',
                                'kubeconfig'
                            ]
                        )

                    }
                }
            }
        }

        // -----------------------------
        // Terraform: infraestructura Workload Identity
        // -----------------------------
        stage('Terraform Deploy Workload Identity') {
            when {
                expression { params.RUN_TERRAFORM_WORKLOAD_IDENTITY }
            }
            environment {
                KUBECONFIG = "${WORKSPACE}/kubeconfig.txt"
            }
            steps {
                dir(env.TF_DIR_WK) {

                    withCredentials([
                        file(credentialsId: 'sops-gpg-key', variable: 'GPG_KEY_FILE')
                    ]) {

                        sh '''
                        set -eo pipefail

                        mkdir -p secrets

                        export GNUPGHOME=$(mktemp -d)

                        gpg --batch --import "$GPG_KEY_FILE"

                        echo "Desencriptando..."
                        sops -d secrets/secrets-enc.yaml | tee secrets/secrets-dec.yaml > /dev/null

                        echo "Verificando archivo..."
                        ls -l secrets
                        '''
                    }
                }

                script {
                    // Validar conexión al cluster
                    sh "kubectl cluster-info"

                    env.JWKS = sh(
                        script: '''
                            kubectl get --raw /openid/v1/jwks | jq -c .
                        ''',
                        returnStdout: true
                    ).trim()
                }

                withCredentials([
                    string(credentialsId: 'hwc-access-key', variable: 'HW_ACCESS_KEY'),
                    string(credentialsId: 'hwc-secret-key', variable: 'HW_SECRET_KEY'),
                    string(credentialsId: 'hwc-access-key', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'hwc-secret-key', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {

                    withEnv([
                        "TF_VAR_oidc_jwks=${env.JWKS}",
                        "TF_VAR_namespace=workload-identity",
                        "TF_VAR_obs_service_account_name=sa-obs-workload-identity",
                        "TF_VAR_dew_service_account_name=sa-dew-workload-identity"
                    ]) {

                        terraformDeploy(
                            dir: env.TF_DIR_WK,
                            varsFile: 'local.tfvars',
                            action: params.ACTION,
                            outputs: ['idp_id']
                        )

                    }

                }
                
            }
        }

        // -----------------------------
        // Helm instalar Addons - Nginx
        // -----------------------------
        stage('Deploy Ingress Nginx') {

            when {
                expression { params.RUN_HELM_ADDONS == 'ingress' }
            }

            environment {
                NAMESPACE = "ingress-nginx"
                TIMEOUT_SECONDS = "240"
                KUBECONFIG = "${WORKSPACE}/kubeconfig.txt"
            }

            steps {
                script {
                    // Lectura de archivos generados en stages previos
                    env.elb_public_id = readFile("${WORKSPACE}/elb_public_id.txt").trim()

                    // Validar conexión al cluster
                    sh "kubectl cluster-info"
                }

                dir(env.HELM_DIR_AO_NI) {

                    sh '''
                    set -eo pipefail

                    echo ""
                    echo "=========================================="
                    echo "Adding Helm repository..."
                    echo "=========================================="

                    helm repo add ingress-nginx https://kubernetes.github.io/ingress-nginx
                    helm repo update

                    echo ""
                    echo "=========================================="
                    echo "Namespace: ${NAMESPACE}"
                    echo "=========================================="

                    sed -i "s/{{ ELB_ID }}/${elb_public_id}/g" values-nginx-ingress.yaml

                    helm upgrade --install nginx-ingress ingress-nginx/ingress-nginx \
                    -n ${NAMESPACE} \
                    --create-namespace \
                    --wait \
                    --timeout ${TIMEOUT_SECONDS}s \
                    --values values-nginx-ingress.yaml

                    echo ""
                    echo "=========================================="
                    echo "Servicios desplegados"
                    echo "=========================================="

                    kubectl get svc -n ${NAMESPACE}
                    '''
                }
            }
        }

        // -----------------------------
        // Helm instalar Addons - Envoy Gateway
        // -----------------------------
        stage('Deploy Gateway API - Envoy Gateway') {

            when {
                expression { params.RUN_HELM_ADDONS == 'gateway' }
            }

            environment {
                NAMESPACE = "envoy-gateway-system"
                TIMEOUT_SECONDS = "300"
                KUBECONFIG = "${WORKSPACE}/kubeconfig.txt"
            }

            steps {
                script {
                    env.elb_public_id = readFile("${WORKSPACE}/elb_public_id.txt").trim()

                    sh "kubectl cluster-info"
                }

                dir(env.HELM_DIR_AO_GA) {

                    sh '''
                    set -eo pipefail

                    echo ""
                    echo "=========================================="
                    echo "Installing Gateway API CRDs..."
                    echo "=========================================="

                    kubectl apply -f https://github.com/kubernetes-sigs/gateway-api/releases/download/v1.1.0/standard-install.yaml

                    echo ""
                    echo "=========================================="
                    echo "Installing Envoy Controller ..."
                    echo "=========================================="

                    sed -i "s/{{ ELB_ID }}/${elb_public_id}/g" envoy-controller/values.yaml

                    helm upgrade --install envoy-gateway oci://docker.io/envoyproxy/gateway-helm \
                    -n ${NAMESPACE} \
                    --create-namespace \
                    --wait \
                    --timeout ${TIMEOUT_SECONDS}s \
                    -f envoy-controller/values.yaml

                    echo ""
                    echo "Waiting for Envoy Gateway deployment..."
                    kubectl rollout status deployment/envoy-gateway -n ${NAMESPACE} --timeout=300s

                    echo ""
                    echo "=========================================="
                    echo "Installing Gateway API Infrastructure ..."
                    echo "=========================================="

                    helm upgrade --install gateway-infra ./gateway-infra \
                    -n ${NAMESPACE} \
                    --create-namespace \
                    --wait \
                    --timeout ${TIMEOUT_SECONDS}s \
                    --set-string elb.id=${elb_public_id}

                    echo "Waiting for Gateway LoadBalancer service..."

                    until kubectl get svc -n ${NAMESPACE} \
                    -l gateway.envoyproxy.io/owning-gateway-name=cluster-gateway \
                    -o name | grep -q service; do
                    sleep 5
                    echo "Waiting for gateway service..."
                    done

                    echo "Associating ELB with Gateway service..."

                    kubectl annotate svc \
                    -l gateway.envoyproxy.io/owning-gateway-name=cluster-gateway \
                    -n ${NAMESPACE} \
                    kubernetes.io/elb.id=${elb_public_id} \
                    --overwrite

                    echo ""
                    echo "=========================================="
                    echo "Gateway API installation completed"
                    echo "=========================================="

                    kubectl get gatewayclass
                    kubectl get gateways -A || true
                    kubectl get svc -n ${NAMESPACE} || true
                    '''
                }
            }
        }

        // -----------------------------
        // Helm desplegar las aplicaciones para Workload Identity
        // -----------------------------
        stage('Deploy Demo App con Workload Identity') {

            when {
                expression { params.RUN_HELM_WORKLOAD_IDENTITY }
            }

            environment {
                NAMESPACE = "workload-identity"
                RELEASE_NAME = "workload-identity"
                TIMEOUT_SECONDS = "300"
                KUBECONFIG = "${WORKSPACE}/kubeconfig.txt"
            }

            steps {
                script {
                    // Lectura de archivos generados en stages previos
                    env.elb_public_id = readFile("${WORKSPACE}/elb_public_id.txt").trim()
                    env.elb_public_ip = readFile("${WORKSPACE}/elb_public_ip.txt").trim()
                    env.idp_id = readFile("${WORKSPACE}/idp_id.txt").trim()

                    // Validar acceso al cluster
                    sh "kubectl cluster-info"

                    // Obtener JWKS
                    env.JWKS = sh(
                        script: "kubectl get --raw /openid/v1/jwks | jq -c .",
                        returnStdout: true
                    ).trim()

                    env.exposure_type = params.RUN_HELM_ADDONS ?: "ingress"
                }

                dir(env.HELM_DIR_WK) {

                    sh '''
                    set -eo pipefail

                    echo ""
                    echo "=========================================="
                    echo "Desplegando Helm Release: ${RELEASE_NAME}"
                    echo "Namespace: ${NAMESPACE}"
                    echo "Chart Dir: workload-identity"
                    echo "=========================================="

                    helm upgrade --install ${RELEASE_NAME} . \
                    -n ${NAMESPACE} \
                    --create-namespace \
                    --wait \
                    --timeout ${TIMEOUT_SECONDS}s \
                    --set elb.id=${elb_public_id} \
                    --set idp_id=${idp_id} \
                    --set demoClient.exposure.type=${exposure_type}

                    echo ""
                    echo "=========================================="
                    echo "Iniciando Health Check público..."
                    echo "ELB IP: ${elb_public_ip}"
                    echo "=========================================="

                    for i in $(seq 1 20); do
                    echo "Intento $i..."
                    if curl -sf http://${elb_public_ip}/index.html; then
                        echo ""
                        echo "Aplicación disponible y funcionando correctamente."
                        exit 0
                    fi
                    sleep 10
                    done
                    '''
                }
            }
        }

        // -----------------------------
        // Helm instalar Argo Rollouts
        // -----------------------------
        stage('Deploy Argo Rollouts') {

            when {
                expression { params.RUN_HELM_ARGO_ROLLOUTS }
            }

            environment {
                NAMESPACE = "argo-rollouts"
                TIMEOUT_SECONDS = "240"
                KUBECONFIG = "${WORKSPACE}/kubeconfig.txt"
            }

            steps {
                script {
                    // Lectura de archivos generados en stages previos
                    env.elb_public_id = readFile("${WORKSPACE}/elb_public_id.txt").trim()

                    // Validar conexión al cluster
                    sh "kubectl cluster-info"
                }

                sh '''
                set -eo pipefail

                echo ""
                echo "=========================================="
                echo "Adding Helm repository..."
                echo "=========================================="

                helm repo add argo https://argoproj.github.io/argo-helm
                helm repo update

                echo ""
                echo "=========================================="
                echo "Namespace: ${NAMESPACE}"
                echo "=========================================="

                helm install argo-rollouts argo/argo-rollouts \
                --namespace ${NAMESPACE} \
                --create-namespace

                echo ""
                echo "=========================================="
                echo "Servicios desplegados"
                echo "=========================================="

                kubectl get pods -n ${NAMESPACE}
                
                '''

            }
        }

        // -----------------------------
        // Clean Workspace
        // -----------------------------
        stage('Clean Workspace') {
            when {
                expression { params.CLEAN_WORKSPACE }
            }
            steps {
                deleteDir()
            }
        }
    }

    post {
        success {
            echo "Pipeline ejecutado correctamente (${params.ACTION})"
        }
        failure {
            echo "Error en el pipeline"
        }
    }
}
