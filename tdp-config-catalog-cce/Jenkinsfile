@Library('shared-lib') _

pipeline {
    agent {
        label 'agent-huawei'
    }

    options {
        disableConcurrentBuilds()
    }

    parameters {
        choice(
            name: 'ACTION',
            choices: ['deploy', 'destroy'],
            description: 'Acción sobre el ambiente'
        )
        choice(
            name: 'CCE_BASE_TYPE',
            choices: ['', 'turbo', 'standard'],
            description: 'Selecciona el tipo de infraestructura base CCE'
        )
        booleanParam(
            name: 'RUN_HELM_ADDONS',
            defaultValue: false,
            description: 'Instalar Addons (nginx-ingress)'
        )    
        booleanParam(
            name: 'RUN_TERRAFORM_WORKLOAD_IDENTITY',
            defaultValue: false,
            description: 'Construir infraestructura con Terraform Workload Identity'
        )
        booleanParam(
            name: 'RUN_HELM_WORKLOAD_IDENTITY',
            defaultValue: false,
            description: 'Desplegar Jenkins con Helm (cargar kubeconfig en secreto)'
        )
    }

    environment {
        TF_DIR_TURBO    = 'tdp-config-catalog-cce/terraform/base-turbo'
        TF_DIR_STANDARD = 'tdp-config-catalog-cce/terraform/base-standard'
        TF_DIR_WK       = 'tdp-config-catalog-cce/terraform/workload-identity'
        HELM_DIR_ADDONS = 'tdp-config-catalog-cce/helm/addons'
        HELM_DIR_WK     = 'tdp-config-catalog-cce/helm/demo-app/workload-identity'
        REGION          = 'la-south-2'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        // -----------------------------
        // Terraform: infraestructura base CCE Turbo
        // -----------------------------
        stage('Terraform Deploy Base Turbo') {
            when {
                expression { params.CCE_BASE_TYPE == 'turbo' }
            }
            steps {
                withCredentials([
                    string(credentialsId: 'hwc-access-key', variable: 'HW_ACCESS_KEY'),
                    string(credentialsId: 'hwc-secret-key', variable: 'HW_SECRET_KEY'),
                    string(credentialsId: 'hwc-access-key', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'hwc-secret-key', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    script {

                        terraformDeploy(
                            dir: env.TF_DIR_TURBO,
                            varsFile: 'local.tfvars',
                            action: params.ACTION,
                            outputs: [
                                'elb_public_ip', 
                                'elb_public_id'
                            ]
                        )

                    }
                }
            }
        }

        // -----------------------------
        // Terraform: infraestructura base CCE Standard
        // -----------------------------
        stage('Terraform Deploy Base Standard') {
            when {
               expression { params.CCE_BASE_TYPE == 'standard' }
            }
            steps {
                withCredentials([
                    string(credentialsId: 'hwc-access-key', variable: 'HW_ACCESS_KEY'),
                    string(credentialsId: 'hwc-secret-key', variable: 'HW_SECRET_KEY'),
                    string(credentialsId: 'hwc-access-key', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'hwc-secret-key', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    script {

                        terraformDeploy(
                            dir: env.TF_DIR_STANDARD,
                            varsFile: 'local.tfvars',
                            action: params.ACTION,
                            outputs: [
                                'elb_public_ip', 
                                'elb_public_id'
                            ]
                        )

                    }
                }
            }
        }

        // -----------------------------
        // Terraform: infraestructura Workload Identity
        // -----------------------------
        stage('Terraform Deploy Workload Identity') {
            when {
                expression { params.RUN_TERRAFORM_WORKLOAD_IDENTITY }
            }
            steps {
                dir(env.TF_DIR_WK) {

                    withCredentials([
                        file(credentialsId: 'sops-gpg-key', variable: 'GPG_KEY_FILE')
                    ]) {

                        sh '''
                        set -eo pipefail

                        mkdir -p secrets

                        export GNUPGHOME=$(mktemp -d)

                        gpg --batch --import "$GPG_KEY_FILE"

                        echo "Desencriptando..."
                        sops -d secrets/secrets-enc.yaml | tee secrets/secrets-dec.yaml > /dev/null

                        echo "Verificando archivo..."
                        ls -l secrets
                        '''
                    }
                }

                script {

                    withCredentials([
                        file(credentialsId: 'cce-app-kubeconfig', variable: 'KUBECONFIG')
                    ]) {

                        env.JWKS = sh(
                            script: '''
                                export KUBECONFIG=$KUBECONFIG
                                kubectl get --raw /openid/v1/jwks | jq -c .
                            ''',
                            returnStdout: true
                        ).trim()
                    }
                }

                withCredentials([
                    string(credentialsId: 'hwc-access-key', variable: 'HW_ACCESS_KEY'),
                    string(credentialsId: 'hwc-secret-key', variable: 'HW_SECRET_KEY'),
                    string(credentialsId: 'hwc-access-key', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'hwc-secret-key', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {

                    withEnv([
                        "TF_VAR_oidc_jwks=${env.JWKS}",
                        "TF_VAR_namespace=workload-identity",
                        "TF_VAR_obs_service_account_name=sa-obs-workload-identity",
                        "TF_VAR_dew_service_account_name=sa-dew-workload-identity"
                    ]) {

                        terraformDeploy(
                            dir: env.TF_DIR_WK,
                            varsFile: 'local.tfvars',
                            action: params.ACTION,
                            outputs: ['idp_id']
                        )

                    }

                }
                
            }
        }

        // -----------------------------
        // Helm instalar Addons
        // -----------------------------
        stage('Deploy Addon Ingress') {

            when {
                expression { params.RUN_HELM_ADDONS }
            }

            environment {
                NAMESPACE = "ingress-nginx"
                TIMEOUT_SECONDS = "60"
            }

            steps {
                script {
                    // Lectura de archivos generados en stages previos
                    env.elb_public_id = readFile("${WORKSPACE}/elb_public_id.txt").trim()
                }

                dir(env.HELM_DIR_ADDONS) {

                    withCredentials([
                        file(credentialsId: 'cce-app-kubeconfig', variable: 'KUBECONFIG')
                    ]) {

                        sh '''
                        set -eo pipefail

                        export KUBECONFIG=$KUBECONFIG

                        echo ""
                        echo "=========================================="
                        echo "Validando acceso al cluster CCE..."
                        echo "=========================================="
                        kubectl get nodes

                        echo ""
                        echo "=========================================="
                        echo "Adding Helm repository..."
                        echo "=========================================="
                        helm repo add ingress-nginx https://kubernetes.github.io/ingress-nginx
                        helm repo update

                        echo ""
                        echo "=========================================="
                        echo "Namespace: ${NAMESPACE}"
                        echo "=========================================="

                        helm upgrade --install nginx-ingress ingress-nginx/ingress-nginx . \
                        -n ${NAMESPACE} \
                        --create-namespace \
                        --wait \
                        --timeout ${TIMEOUT_SECONDS}s \
                        --values values-nginx-ingress.yaml
                        --set controller.service.kubernetes.io/elb.id=${elb_public_id}

                        '''
                    }
                }
            }
        }

        // -----------------------------
        // Helm desplegar las aplicaciones para Workload Identity
        // -----------------------------
        stage('Deploy Demo App con Workload Identity') {

            when {
                expression { params.RUN_HELM_WORKLOAD_IDENTITY }
            }

            environment {
                NAMESPACE = "workload-identity"
                RELEASE_NAME = "workload-identity"
                TIMEOUT_SECONDS = "300"
            }

            steps {
                script {
                    // Lectura de archivos generados en stages previos
                    env.elb_public_id = readFile("${WORKSPACE}/elb_public_id.txt").trim()
                    env.elb_public_ip = readFile("${WORKSPACE}/elb_public_ip.txt").trim()
                    env.idp_id = readFile("${WORKSPACE}/idp_id.txt").trim()
                    env.JWKS = sh(script: "kubectl get --raw /openid/v1/jwks | jq -c .", returnStdout: true).trim()
                }

                dir(env.HELM_DIR_WK) {

                    withCredentials([
                        file(credentialsId: 'cce-app-kubeconfig', variable: 'KUBECONFIG')
                    ]) {

                        sh '''
                        set -eo pipefail

                        export KUBECONFIG=$KUBECONFIG

                        echo ""
                        echo "=========================================="
                        echo "Validando acceso al cluster CCE..."
                        echo "=========================================="

                        kubectl get nodes

                        echo ""
                        echo "=========================================="
                        echo "Desplegando Helm Release: ${RELEASE_NAME}"
                        echo "Namespace: ${NAMESPACE}"
                        echo "Chart Dir: workload-identity"
                        echo "=========================================="

                        helm upgrade --install ${RELEASE_NAME} . \
                        -n ${NAMESPACE} \
                        --create-namespace \
                        --wait \
                        --timeout ${TIMEOUT_SECONDS}s \
                        --set elb.id=${elb_public_id} \
                        --set idp_id=${idp_id} 

                        echo ""
                        echo "=========================================="
                        echo "Iniciando Health Check público..."
                        echo "ELB IP: ${elb_public_ip}"
                        echo "=========================================="

                        for i in \$(seq 1 20); do
                        echo "Intento \$i..."
                        if curl -sf http://${elb_public_ip}/index.html; then
                            echo ""
                            echo "Aplicación disponible y funcionando correctamente."
                            exit 0
                        fi
                        sleep 10
                        done

                        '''
                    }
                }
            }
        }

        // -----------------------------
        // Clean Workspace
        // -----------------------------
        stage('Clean Workspace') {
            when {
                expression { params.CLEAN_WORKSPACE }
            }
            steps {
                deleteDir()
            }
        }
    }

    post {
        success {
            echo "Pipeline ejecutado correctamente (${params.ACTION})"
        }
        failure {
            echo "Error en el pipeline"
        }
    }
}
